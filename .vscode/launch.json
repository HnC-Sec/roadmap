    "version": "0.2.0",
    "configurations": [
    {
      "type": "go",
      "request": "launch",
      "name": "Hugo Server",
      "mode": "exec",
      "program": "/usr/local/hugo/bin/hugo",
      "args": [
        "server",
        "--bind", "0.0.0.0",
        "--port", "1313",
        "--poll", "1000ms",
        "--buildDrafts"
      ],
      "cwd": "${workspaceFolder}/roadmap"
    }
  ]
}